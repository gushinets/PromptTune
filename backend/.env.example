# Database
DATABASE_URL=postgresql+asyncpg://prompttune:prompttune@localhost:5432/prompttune

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM Backend Selection
LLM_BACKEND=OPENROUTER

# Allowed values: OPENAI, OPENROUTER
# LLM Model
LLM_MODEL=gpt-4o-mini

# LLM request timeout (seconds) for LiteLLM upstream calls
LLM_REQUEST_TIMEOUT_SECONDS=60

# OpenRouter attribution (optional; defaults match prior HTTP-Referer / X-Title behavior)
# OPENROUTER_SITE_URL=https://prompttune.local
# OPENROUTER_APP_NAME=PromptTune

# API Keys (required based on LLM_BACKEND)
# Never commit real keys. Populate these locally or via your deployment secrets.
# Use OPENAI_API_KEY only when LLM_BACKEND=OPENAI
OPENAI_API_KEY=
# Use OPENROUTER_API_KEY only when LLM_BACKEND=OPENROUTER
OPENROUTER_API_KEY=

# Rate limits
FREE_REQ_PER_DAY=50
FREE_REQ_PER_MIN=10

# Security
MAX_TEXT_LENGTH=8000
ALLOWED_ORIGINS=*

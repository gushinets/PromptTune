# PromptTune — environment template (single source of truth for example values).
#
# Docker Compose: copy to infra/.env
#   cp .env.example .env
#
# Local uvicorn without Docker: copy the variables you need into backend/.env and
# point DATABASE_URL / REDIS_URL at localhost (see commented hints below).
#
# Never commit real API keys or production passwords.

# --- PostgreSQL (Docker Compose: consumed by postgres service; align DATABASE_URL password) ---
POSTGRES_USER=prompttune
# Dev: a simple password is fine. Production: use a strong unique value.
POSTGRES_PASSWORD=prompttune
POSTGRES_DB=prompttune

# --- Application (api container env_file; same keys as backend/.env for local runs) ---

# Docker Compose (service hostnames):
DATABASE_URL=postgresql+asyncpg://prompttune:prompttune@postgres:5432/prompttune
REDIS_URL=redis://redis:6379/0

# Local (no Docker):
# DATABASE_URL=postgresql+asyncpg://prompttune:prompttune@localhost:5432/prompttune
# REDIS_URL=redis://localhost:6379/0

# Production (example — replace POSTGRES_PASSWORD and match DATABASE_URL):
# POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# DATABASE_URL=postgresql+asyncpg://prompttune:CHANGE_ME_STRONG_PASSWORD@postgres:5432/prompttune

# LLM Backend Selection
LLM_BACKEND=OPENROUTER

# Allowed values: OPENAI, OPENROUTER
# LLM Model
LLM_MODEL=gpt-4o-mini

# LLM request timeout (seconds) for LiteLLM upstream calls
LLM_REQUEST_TIMEOUT_SECONDS=60

# OpenRouter attribution (optional; defaults match prior HTTP-Referer / X-Title behavior)
# OPENROUTER_SITE_URL=https://prompttune.local
# OPENROUTER_APP_NAME=PromptTune

# API Keys (required based on LLM_BACKEND)
# Never commit real keys. Populate these locally or via your deployment secrets.
# Use OPENAI_API_KEY only when LLM_BACKEND=OPENAI
OPENAI_API_KEY=
# Use OPENROUTER_API_KEY only when LLM_BACKEND=OPENROUTER
OPENROUTER_API_KEY=

# Rate limits
FREE_REQ_PER_DAY=50
FREE_REQ_PER_MIN=10

# Prompt and generation limits (backend-owned)
PROMPT_INPUT_MAX_CHARS=8000
PROMPT_OUTPUT_MAX_CHARS=12000
LLM_COMPLETION_TOKENS=8192
LLM_COMPLETION_TOKENS_RETRY_MAX=12288
# Total attempts for LLM call (first call + retries)
LLM_MAX_RETRIES=2
# Optional: if empty/not set, temperature is not sent upstream
LLM_TEMPERATURE=0.7

# Identity hashing salts (change in production, keep secret)
# Used by Redis canonicalization for installation_id and IP hashes.
INSTALLATION_ID_SALT=prompttune-installation
IP_SALT=prompttune-ip

# Security
# MVP deployment note: keep ALLOWED_ORIGINS=* until published extension IDs/origins are known; tighten later.
ALLOWED_ORIGINS=*

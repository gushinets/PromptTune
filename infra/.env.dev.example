# Postgres
POSTGRES_USER=prompttune
POSTGRES_PASSWORD=prompttune
POSTGRES_DB=prompttune

# App
DATABASE_URL=postgresql+asyncpg://prompttune:prompttune@postgres:5432/prompttune
REDIS_URL=redis://redis:6379/0
LLM_BACKEND=OPENROUTER
LLM_MODEL=gpt-4o-mini
# Allowed values: OPENAI, OPENROUTER
# Use OPENROUTER_API_KEY only when LLM_BACKEND=OPENROUTER
OPENROUTER_API_KEY=
# Use OPENAI_API_KEY only when LLM_BACKEND=OPENAI
OPENAI_API_KEY=
FREE_REQ_PER_DAY=50
FREE_REQ_PER_MIN=10
MAX_TEXT_LENGTH=8000
ALLOWED_ORIGINS=*

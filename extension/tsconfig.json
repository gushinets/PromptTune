{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["shared/*"],
      "@adapters/*": ["adapters/*"]
    }
  },
  "include": [
    ".wxt/wxt.d.ts",
    "entrypoints/**/*.ts",
    "entrypoints/**/*.tsx",
    "shared/**/*.ts",
    "adapters/**/*.ts",
    "__tests__/**/*.ts",
    "__tests__/**/*.tsx"
  ]
}
